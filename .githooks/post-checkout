#!/usr/bin/env bash
# ============================================================
#  platform_serial — post-checkout hook
#
#  Triggered by:  git checkout -b <branch>
#                 git switch -c <branch>
#
#  Detects new branch creation ($1 == $2 AND $3 == 1) and runs
#  the quality gate so you always start from a clean state.
#
#  Args:
#    $1  previous HEAD (sha)
#    $2  new HEAD (sha)
#    $3  1 = branch checkout, 0 = file checkout
#
#  Skip: set GIT_HOOKS_BYPASS=1
# ============================================================

PREV_HEAD="$1"
NEW_HEAD="$2"
CHECKOUT_TYPE="$3"   # 1=branch, 0=file

# Only act on branch checkouts
[ "${CHECKOUT_TYPE}" -eq 1 ] || exit 0

# Detect NEW branch creation: prev HEAD == new HEAD
# (git checkout -b / git switch -c points new branch to current commit)
[ "${PREV_HEAD}" = "${NEW_HEAD}" ] || exit 0

# ── Source shared library ─────────────────────────────────────
source "$(dirname "$0")/_lib.sh"

BRANCH=$(current_branch)

hdr "🌿 New branch: ${BRANCH}"
echo "   Verifying starting quality state..."

require_flutter || exit 0

cd "${REPO_ROOT}"

FAILED=0

# ── 1. Dart analysis ─────────────────────────────────────────
log "1/3 — Static analysis..."
if flutter analyze --fatal-infos --fatal-warnings \
     --no-pub 2>&1 | tail -3; then
  ok "Static analysis passed"
else
  err "Static analysis failed"
  FAILED=1
fi

# ── 2. Quick test run ─────────────────────────────────────────
log "2/3 — Running test suite..."
if flutter test --coverage 2>&1 | tail -5; then
  ok "Tests passed"
else
  err "Tests failed"
  FAILED=1
fi

# ── 3. Coverage gate ─────────────────────────────────────────
log "3/3 — Coverage gate..."
if [ -f "${REPO_ROOT}/coverage/lcov.info" ]; then
  if dart run tool/coverage_gate.dart \
         --lcov coverage/lcov.info --min-lines 100 2>&1; then
    ok "Coverage gate passed"
  else
    err "Coverage gate failed"
    FAILED=1
  fi
else
  warn "lcov.info not found — coverage check skipped"
fi

echo ""
if [ "${FAILED}" -ne 0 ]; then
  warn "Quality gate issues detected on branch start."
  warn "Fix the above before adding new code to '${BRANCH}'."
  warn "To bypass: GIT_HOOKS_BYPASS=1 git checkout -b ${BRANCH}"
  # Do NOT exit 1 here: post-checkout can't abort branch creation.
  # We warn but let the developer proceed.
else
  ok "Branch '${BRANCH}' starts from a clean state. Happy coding! 🚀"
fi

echo ""
