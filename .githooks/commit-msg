#!/usr/bin/env bash
# ============================================================
#  platform_serial — commit-msg hook
#
#  Enforces Conventional Commits format:
#    <type>(<optional scope>): <description>
#
#  Valid types:  feat | fix | docs | test | chore
#               refactor | style | ci | build | perf | revert
#
#  Examples (valid):
#    feat(web): add Web Serial API support
#    fix: resolve null safety issue in SerialPort
#    docs: update README web section
#    test(web): add WebSerialImpl unit tests
#    chore: bump dependencies
#    feat!: breaking change in SerialConfig API
#
#  Skip: set GIT_HOOKS_BYPASS=1
# ============================================================

source "$(dirname "$0")/_lib.sh"

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "${COMMIT_MSG_FILE}")

# Strip comments and trailing whitespace
SUBJECT=$(echo "${COMMIT_MSG}" | grep -v '^#' | head -1 | sed 's/[[:space:]]*$//')

hdr "📝 commit-msg validation"

# ── Allow empty commits (e.g., --allow-empty) ────────────────
if [ -z "${SUBJECT}" ]; then
  warn "Empty commit message — allowed but not recommended."
  exit 0
fi

# ── Allow merge commits ──────────────────────────────────────
if echo "${SUBJECT}" | grep -qE '^Merge (branch|pull request|remote)'; then
  ok "Merge commit: skipping format check"
  exit 0
fi

# ── Allow revert commits generated by git ────────────────────
if echo "${SUBJECT}" | grep -qE '^Revert "'; then
  ok "Revert commit: skipping format check"
  exit 0
fi

# ── Validate Conventional Commits format ────────────────────
if echo "${SUBJECT}" | grep -qP "${CC_PATTERN}"; then
  ok "Commit message format: valid"
  exit 0
fi

# ── Fail with helpful guidance ───────────────────────────────
err "Commit message does not follow Conventional Commits:"
echo ""
echo "  Got:      ${SUBJECT}"
echo ""
echo "  Expected: <type>(<scope>): <description>"
echo ""
echo "  Types:    feat  fix  docs  test  chore  refactor"
echo "            style  ci  build  perf  revert"
echo ""
echo "  Examples:"
echo "    feat(web): add Web Serial API support"
echo "    fix: resolve null safety issue in SerialPort"
echo "    docs: update README web section"
echo "    test: add WebSerialImpl unit tests"
echo "    chore: bump dependencies"
echo "    feat!: BREAKING — rename SerialConfig.port"
echo ""
echo "  See: https://www.conventionalcommits.org"
echo ""
echo "  Bypass: GIT_HOOKS_BYPASS=1 git commit ..."
echo ""
exit 1
