# Local development and agent runtime state
.crew/
.pi/
.dart_tool/
build/
coverage/

# IDE/editor state
.idea/
.vscode/

# Examples directory — excluded from the published pub package.
# Pub convention is example/ (singular); this repo uses examples/<name>/
# for clarity but the plugin itself has no runtime dependency on examples.
examples/

# Generated example build outputs
example/.dart_tool/
example/build/
example/.flutter-plugins
example/.flutter-plugins-dependencies

# Temporary logs and reports
*.log
*.tmp
subagent-*.md
example/linux/flutter/ephemeral/
example/macos/Flutter/ephemeral/
example/windows/flutter/ephemeral/
