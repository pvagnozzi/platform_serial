* text=auto eol=lf

# Shell scripts must remain executable-friendly on Unix
*.sh text eol=lf

# Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Source files
*.dart text eol=lf
*.kt text eol=lf
*.swift text eol=lf
*.m text eol=lf
*.mm text eol=lf
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.h text eol=lf

# Binary artifacts
*.dll binary
*.so binary
*.dylib binary
*.a binary
*.lib binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
