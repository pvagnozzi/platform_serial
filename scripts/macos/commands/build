#!/usr/bin/env bash
# ============================================================
#  🏗️  build — platform_serial Docker Build Command
#  Builds the Flutter web output using the builder container.
#  With --force, both the base and builder images are rebuilt
#  from scratch before the container is run.
# ============================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
COMPOSE_FILE="${REPO_ROOT}/containers/docker-compose.yml"

bold='\033[1m'; green='\033[32m'; yellow='\033[33m'; red='\033[31m'; cyan='\033[36m'; reset='\033[0m'
log()  { printf "%b%s%b\n" "$cyan"   "  $1" "$reset"; }
ok()   { printf "%b✅  %s%b\n" "$green"  "$1" "$reset"; }
warn() { printf "%b⚠️   %s%b\n" "$yellow" "$1" "$reset"; }
fail() { printf "%b❌  %s%b\n" "$red"   "$1" "$reset"; exit 1; }
run()  { if [[ "$DRY_RUN" == 1 ]]; then warn "dry-run: $*"; else eval "$@"; fi; }

DRY_RUN=0; FORCE=0; TARGET="web-js"; NO_CACHE=""

usage() {
  cat <<'EOF'
🏗️  build — Run the platform_serial Docker builder container

Synopsis:
  scripts/macos/commands/build [options]

Options:
      --dry-run       Print actions without executing them.
      --force         Force rebuild of Docker images (--no-cache).
      --target NAME   Build target: web-js | web-wasm | pubdry (default: web-js).
  -h, --help          Show this help.

Examples:
  scripts/macos/commands/build                    # build Flutter web (JS)
  scripts/macos/commands/build --target web-wasm  # build Flutter web (WASM)
  scripts/macos/commands/build --target pubdry    # validate pub.dev metadata
  scripts/macos/commands/build --force            # rebuild images from scratch
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)  DRY_RUN=1 ;;
    --force)    FORCE=1; NO_CACHE="--no-cache" ;;
    --target)   TARGET="$2"; shift ;;
    -h|--help)  usage; exit 0 ;;
    *)          fail "Unknown option: $1" ;;
  esac
  shift
done

printf "%b%s%b\n" "$bold" "🏗️  platform_serial — Docker Build (target: ${TARGET})" "$reset"

command -v docker >/dev/null 2>&1 || fail "Docker not found. Install Docker Desktop first."

log "📦 Building base image..."
run "docker compose -f '${COMPOSE_FILE}' build ${NO_CACHE} base"

log "📦 Building builder image..."
run "docker compose -f '${COMPOSE_FILE}' build ${NO_CACHE} builder"

log "🏗️  Running builder (target: ${TARGET})..."
run "BUILD_TARGET=${TARGET} docker compose -f '${COMPOSE_FILE}' run --rm builder"

ok "Build complete (target: ${TARGET})"
