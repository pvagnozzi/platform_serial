#!/usr/bin/env bash
# ============================================================
#  🧑‍💻 devcontainer — platform_serial DevContainer Launcher
#  Builds and starts the full development container with an
#  interactive shell. Docker socket is mounted for sibling
#  container operations.
# ============================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
COMPOSE_FILE="${REPO_ROOT}/containers/docker-compose.yml"

bold='\033[1m'; green='\033[32m'; yellow='\033[33m'; red='\033[31m'; cyan='\033[36m'; reset='\033[0m'
log()  { printf "%b%s%b\n" "$cyan"   "  $1" "$reset"; }
ok()   { printf "%b✅  %s%b\n" "$green"  "$1" "$reset"; }
warn() { printf "%b⚠️   %s%b\n" "$yellow" "$1" "$reset"; }
fail() { printf "%b❌  %s%b\n" "$red"   "$1" "$reset"; exit 1; }
run()  { if [[ "$DRY_RUN" == 1 ]]; then warn "dry-run: $*"; else eval "$@"; fi; }

DRY_RUN=0; FORCE=0; NO_CACHE=""; SHELL_CMD="/bin/bash"

usage() {
  cat <<'EOF'
🧑‍💻 devcontainer — Start the platform_serial development container

Synopsis:
  scripts/linux/commands/devcontainer [options] [-- COMMAND...]

Options:
      --dry-run     Print actions without executing them.
      --force       Force rebuild of the devcontainer image.
  -h, --help        Show this help.

Examples:
  scripts/linux/commands/devcontainer              # interactive shell
  scripts/linux/commands/devcontainer --force      # rebuild + start
  scripts/linux/commands/devcontainer -- flutter test  # run one command
EOF
}

EXTRA_CMD=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)  DRY_RUN=1 ;;
    --force)    FORCE=1; NO_CACHE="--no-cache" ;;
    -h|--help)  usage; exit 0 ;;
    --)         shift; EXTRA_CMD=("$@"); break ;;
    *)          fail "Unknown option: $1" ;;
  esac
  shift
done

printf "%b%s%b\n" "$bold" "🧑‍💻 platform_serial — DevContainer" "$reset"

command -v docker >/dev/null 2>&1 || fail "Docker not found. Install Docker Desktop first."

log "📦 Building devcontainer image..."
run "docker compose -f '${COMPOSE_FILE}' build ${NO_CACHE} devcontainer"

if [[ ${#EXTRA_CMD[@]} -gt 0 ]]; then
  log "▶️  Running: ${EXTRA_CMD[*]}"
  run "docker compose -f '${COMPOSE_FILE}' run --rm devcontainer ${EXTRA_CMD[*]}"
else
  log "🐚 Starting interactive shell..."
  run "docker compose -f '${COMPOSE_FILE}' run --rm --service-ports devcontainer"
fi

ok "DevContainer session ended"
